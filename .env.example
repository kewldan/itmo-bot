# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# PostgreSQL (asyncpg). Для docker compose менять не нужно.
DATABASE_URL=postgresql://itmo:itmo@postgres:5432/itmo

# Valkey/Redis для FSM-состояний бота (опционально; без него — память процесса)
REDIS_URL=redis://valkey:6379/0

# Telegram ID администратора — уведомления о новых пользователях.
# Свой ID можно узнать командой /id у бота.
# ADMIN_TG_ID=123456789

# Как часто опрашивать сайт, секунд (список обновляется примерно раз в час)
POLL_INTERVAL_SECONDS=600

# Дата окончания приёма оплат по договорам (горизонт прогноза «к зачислению»)
ENROLL_DEADLINE=2026-08-20

# Дата окончания приёма заявлений (горизонт притока новых конкурентов)
APPLY_DEADLINE=2026-08-10
